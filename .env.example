# PostgreSQL (Vercel Postgres / Neon — use pooled connection string on serverless)
DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require
# Alternative name supported by Vercel:
# POSTGRES_URL=

JWT_SECRET=your_long_random_secret

# Email (Gmail app password)
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# Optional: force SSL for local Postgres
# PGSSLMODE=require

# Vercel Blob — file uploads in production (create token in Vercel dashboard → Storage)
BLOB_READ_WRITE_TOKEN=

# Optional overrides
# UPLOADS_DIR=./public/uploads
# MAX_FILE_SIZE=20971520

# UPI / payments
# UPI_ID=
# UPI_NAME=

# AI quiz
# GROQ_API_KEY=
